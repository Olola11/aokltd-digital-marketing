# ============================================================
# Apotheosis of Knowledge — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local to Git.
# ============================================================

# --- Vercel KV (Redis) ---
# Create a KV database at: vercel.com → Project → Storage
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Resend (Email) ---
# Sign up at: resend.com
# Verify domain: aokltd.org
RESEND_API_KEY=
PROSPECTUS_FROM_EMAIL=prospectus@aokltd.org

# --- Admin ---
# Set a strong random secret for admin API access
# Generate one: openssl rand -hex 32
ADMIN_SECRET_KEY=

# --- Site URL ---
# Set to your production URL
NEXT_PUBLIC_SITE_URL=https://aokltd.org
